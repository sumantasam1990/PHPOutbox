{
    "name": "phpoutbox/outbox",
    "description": "Transactional Outbox Pattern for PHP — guaranteed at-least-once event delivery for Laravel, Symfony, and vanilla PHP",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "outbox",
        "transactional-outbox",
        "event-driven",
        "message-relay",
        "at-least-once",
        "dual-write",
        "laravel",
        "symfony",
        "php"
    ],
    "homepage": "https://github.com/phpoutbox/outbox",
    "authors": [
        {
            "name": "PHPOutbox Contributors",
            "email": "hello@phpoutbox.dev"
        }
    ],
    "require": {
        "php": "^8.2",
        "psr/log": "^3.0",
        "psr/clock": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "orchestra/testbench": "^9.0",
        "symfony/messenger": "^7.0",
        "symfony/http-kernel": "^7.0",
        "symfony/dependency-injection": "^7.0",
        "symfony/config": "^7.0",
        "symfony/console": "^7.0",
        "symfony/yaml": "^7.0"
    },
    "suggest": {
        "ext-pdo_mysql": "Required for MySQL outbox store",
        "ext-pdo_pgsql": "Required for PostgreSQL outbox store",
        "orchestra/testbench": "Required for Laravel adapter testing",
        "symfony/messenger": "Required for Symfony Messenger publisher",
        "symfony/http-kernel": "Required for Symfony bundle"
    },
    "autoload": {
        "psr-4": {
            "PhpOutbox\\Outbox\\": "src/",
            "PhpOutbox\\Outbox\\Laravel\\": "src-laravel/",
            "PhpOutbox\\Outbox\\Symfony\\": "src-symfony/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpOutbox\\Outbox\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PhpOutbox\\Outbox\\Laravel\\OutboxServiceProvider"
            ],
            "aliases": {
                "Outbox": "PhpOutbox\\Outbox\\Laravel\\Facades\\Outbox"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
